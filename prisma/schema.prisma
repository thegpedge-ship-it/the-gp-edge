  subjects        subjects          @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, subject_id])
  @@index([user_id, strength], map: "idx_mastery_user_strength")
}

model users {
  id                                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerk_user_id                     String                     @unique
  email                             String                     @unique @db.Citext
  first_name                        String?
  last_name                         String?
  avatar_file_id                    String?                    @db.Uuid
  role_title                        String?
  hospital                          String?
  location                          String?
  bio                               String?
  racgp_id                          String?
  exam_target                       String?
  status                            account_status             @default(active)
  joined_at                         DateTime                   @default(now()) @db.Timestamptz(6)
  last_active_at                    DateTime?                  @db.Timestamptz(6)
  created_at                        DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime                   @default(now()) @db.Timestamptz(6)
  deleted_at                        DateTime?                  @db.Timestamptz(6)
  autofill_usages                   autofill_usages[]
  files_files_uploaded_byTousers    files[]                    @relation("files_uploaded_byTousers")
  payments                          payments[]
  promo_redemptions                 promo_redemptions[]
  quiz_configs                      quiz_configs[]
  subscriptions                     subscriptions?
  test_attempts                     test_attempts[]
  user_activity_events              user_activity_events[]
  user_badge_progress               user_badge_progress[]
  user_badges                       user_badges[]
  user_favourite_mbs_items          user_favourite_mbs_items[]
  user_notifications                user_notifications[]
  user_performance_summary          user_performance_summary?
  user_preferences                  user_preferences?
  user_question_bookmarks           user_question_bookmarks[]
  user_saved_templates              user_saved_templates[]
  user_subject_mastery              user_subject_mastery[]
  files_users_avatar_file_idTofiles files?                     @relation("users_avatar_file_idTofiles", fields: [avatar_file_id], references: [id], onUpdate: NoAction)
}

